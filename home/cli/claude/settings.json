{
  "model": "opus[1m]",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "switchModelsOnFlag": false,
  "cleanupPeriodDays": 365,
  "enableAllProjectMcpServers": false,
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/test-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/audit-log.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/fschade/.claude/statusline-command.sh"
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git branch --show-current)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(git worktree list)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(jq *)",
      "Bash(nix eval *)",
      "Bash(nix flake check)",
      "Bash(nix flake check *)",
      "Bash(nix flake show)",
      "Bash(nix flake show *)",
      "Bash(nix flake metadata)",
      "Bash(mise tasks)",
      "Bash(mise tasks *)",
      "Bash(mise ls)"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Edit(~/.claude/settings.json)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.config/sops/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.git-credentials)",
      "Read(~/.npmrc)",
      "Read(~/Library/Keychains/**)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
